# ── Database ──────────────────────────────────────────────────────
# DB_HOST 在 Docker 环境中固定为 db（容器名），不需要改
DB_HOST=db
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_strong_password_here
DB_NAME=news_app

# ── API Keys ──────────────────────────────────────────────────────
NEWS_API_KEY=your_newsapi_key_here
OPENAI_API_KEY=your_openai_key_here

# ── App Settings ──────────────────────────────────────────────────
TOKEN_TTL_DAYS=7
DEBUG=false
SQLALCHEMY_ECHO=false
CORS_ORIGINS=*

# ── Admin ─────────────────────────────────────────────────────────
ADMIN_SECRET=change_me_to_a_strong_random_string

# ── DB Pool（可选调整）────────────────────────────────────────────
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
